<!DOCTYPE html>
<html>
  <head>
    <title>Admin | <%= business_setting.business_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <% admin_tour_page = {
    "admin/dashboard" => "dashboard",
    "admin/orders" => "orders",
    "admin/bookings" => "bookings",
    "admin/menu_items" => "menu-items",
    "admin/categories" => "categories",
    "admin/opening_hours" => "hours",
    "admin/settings" => "settings"
  }[controller_path] || "admin" %>

  <body class="admin-shell min-h-screen text-neutral-900"
        data-controller="admin-tour"
        data-admin-tour-page-value="<%= admin_tour_page %>"
        data-admin-tour-storage-key-value="juicy_admin_tour_seen_v1"
        data-action="keydown.esc@window->admin-tour#close">
    <header class="border-b border-black/10 bg-[#24211f] text-white">
      <div class="container-shell flex flex-wrap items-center justify-between gap-4 py-4">
        <div class="flex items-center gap-3">
          <span class="brand-mark">JD</span>
          <div>
            <p class="text-lg font-black">Restaurant Admin</p>
            <p class="text-xs font-semibold text-[#f4c84a]"><%= business_setting.business_name %> operations</p>
          </div>
        </div>
        <nav class="flex flex-wrap items-center gap-2 text-sm">
          <%= link_to "Dashboard", admin_root_path, class: admin_nav_link_classes(admin_root_path) %>
          <%= link_to "Orders", admin_orders_path, class: admin_nav_link_classes(admin_orders_path) %>
          <%= link_to "Bookings", admin_bookings_path, class: admin_nav_link_classes(admin_bookings_path) %>
          <%= link_to "Menu Items", admin_menu_items_path, class: admin_nav_link_classes(admin_menu_items_path) %>
          <%= link_to "Categories", admin_categories_path, class: admin_nav_link_classes(admin_categories_path) %>
          <%= link_to "Hours", admin_opening_hours_path, class: admin_nav_link_classes(admin_opening_hours_path) %>
          <%= link_to "Settings", edit_admin_settings_path, class: admin_nav_link_classes(edit_admin_settings_path) %>
          <button type="button"
                  class="rounded-full border border-[#f4c84a]/60 bg-[#f4c84a]/15 px-3 py-2 text-sm font-extrabold text-[#f4c84a] transition hover:bg-[#f4c84a] hover:text-neutral-950"
                  data-action="admin-tour#openPageGuide">
            Show guide
          </button>
          <%= link_to "View Site", root_path, class: "rounded-full bg-white px-3 py-2 text-sm font-extrabold text-neutral-950 transition hover:bg-[#f4c84a]" %>
        </nav>
      </div>
    </header>

    <%= render "shared/flash" %>

    <main class="container-shell py-8">
      <%= yield %>
    </main>

    <div class="admin-tour hidden" data-admin-tour-target="modal">
      <div class="admin-tour__backdrop"></div>
      <section class="admin-tour__panel"
               role="dialog"
               aria-modal="true"
               aria-labelledby="admin-tour-title"
               aria-describedby="admin-tour-body">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="admin-label" data-admin-tour-target="eyebrow">Admin guide</p>
            <h2 id="admin-tour-title" class="mt-2 text-2xl font-black text-neutral-950 sm:text-3xl" data-admin-tour-target="title"></h2>
          </div>
          <button type="button"
                  class="admin-tour__icon-button"
                  aria-label="Close guide"
                  data-admin-tour-target="closeButton"
                  data-action="admin-tour#close">
            &times;
          </button>
        </div>

        <p id="admin-tour-body" class="mt-4 text-base leading-7 text-neutral-700" data-admin-tour-target="body"></p>

        <div class="mt-6 flex items-center justify-between gap-4">
          <div class="flex gap-2" data-admin-tour-target="dots" aria-hidden="true"></div>
          <p class="text-sm font-bold text-neutral-500" data-admin-tour-target="count"></p>
        </div>

        <div class="mt-6 flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-between">
          <button type="button"
                  class="admin-tour__text-button"
                  data-admin-tour-target="skipButton"
                  data-action="admin-tour#skip">
            Skip tour
          </button>
          <div class="flex flex-col gap-3 sm:flex-row">
            <button type="button"
                    class="btn-secondary justify-center"
                    data-admin-tour-target="backButton"
                    data-action="admin-tour#back">
              Back
            </button>
            <button type="button"
                    class="btn-primary justify-center"
                    data-admin-tour-target="nextButton"
                    data-action="admin-tour#next">
              Next
            </button>
            <button type="button"
                    class="btn-primary justify-center"
                    data-admin-tour-target="finishButton"
                    data-action="admin-tour#finish">
              Finish
            </button>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
