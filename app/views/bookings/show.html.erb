<section class="container-shell">
  <div class="section-card p-6 md:p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">Booking Received</p>
    <h1 class="mt-2 text-4xl">Thanks, <%= @booking.name %>.</h1>
    <p class="mt-2 text-sm text-neutral-600">Your booking request has been submitted.</p>

    <div class="mt-6 rounded-2xl border border-neutral-200 bg-white p-4 text-sm">
      <p><span class="font-semibold">Date & Time:</span> <%= @booking.booking_time.strftime("%a %d %b, %I:%M %p") %></p>
      <p><span class="font-semibold">Party Size:</span> <%= @booking.party_size %></p>
      <p><span class="font-semibold">Status:</span> <%= @booking.status.humanize %></p>
    </div>

    <div class="mt-6 flex gap-3">
      <%= link_to "Back to Home", root_path, class: "btn-secondary" %>
      <%= link_to "Book Another", book_path, class: "btn-primary" %>
    </div>
  </div>
</section>
