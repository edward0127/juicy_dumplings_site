<section class="warm-band">
  <div class="container-shell py-10">
    <p class="eyebrow">Reservations</p>
    <h1 class="mt-2 max-w-3xl text-5xl leading-tight text-neutral-950 md:text-6xl">Book a casual table for dumplings.</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-neutral-700">Choose a date and timeslot within opening hours. Staff will confirm your booking after submission.</p>
  </div>
</section>

<section class="container-shell grid gap-6 py-10 lg:grid-cols-[1.15fr_0.85fr]">
  <div class="section-card p-6 md:p-8">
    <% if @booking&.errors&.any? %>
      <div class="mb-5 rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">
        <ul class="list-disc pl-5">
          <% @booking.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: (@booking || Booking.new), url: book_path, class: "space-y-4", data: { controller: "booking-slots" } do |f| %>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="form-label" for="slot_date">Date</label>
          <%= date_field_tag :date, @selected_date, id: "slot_date", class: "input-field", data: { booking_slots_target: "date", action: "change->booking-slots#loadSlots" } %>
        </div>

        <div>
          <%= f.label :booking_time, "Time", class: "form-label" %>
          <%= f.select :booking_time, @available_slots.map { |slot| [slot.strftime("%a %d %b, %I:%M %p"), slot] }, { include_blank: "Select a timeslot" }, class: "input-field", data: { booking_slots_target: "time" } %>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <%= f.label :name, "Name", class: "form-label" %>
          <%= f.text_field :name, class: "input-field", required: true %>
        </div>
        <div>
          <%= f.label :party_size, "Guests", class: "form-label" %>
          <%= f.number_field :party_size, in: 1..20, class: "input-field", required: true %>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <%= f.label :phone, "Phone", class: "form-label" %>
          <%= f.telephone_field :phone, class: "input-field" %>
        </div>
        <div>
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, class: "input-field" %>
        </div>
      </div>

      <div>
        <%= f.label :notes, "Booking Notes", class: "form-label" %>
        <%= f.text_area :notes, rows: 4, class: "input-field", placeholder: "High chair, dietary notes, event details" %>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <%= f.submit "Request Booking", class: "btn-primary justify-center" %>
        <%= link_to "Order takeaway instead", order_path, class: "btn-secondary justify-center" %>
      </div>
    <% end %>
  </div>

  <aside class="space-y-4">
    <div class="overflow-hidden rounded-lg border border-[#e6d7bd] bg-white shadow-xl">
      <%= image_tag "shop_front.jpg", alt: "#{business_setting.business_name} shop front", class: "h-72 w-full object-cover" %>
      <div class="p-5">
        <h2 class="text-3xl text-neutral-950">Before you arrive</h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-neutral-600">
          <li>Bookings are confirmed by staff after submission.</li>
          <li>Please arrive within 10 minutes of your booking time.</li>
          <li>For larger groups, include details in notes.</li>
        </ul>
      </div>
    </div>

    <div class="section-card p-5">
      <p class="eyebrow">Need immediate help?</p>
      <p class="mt-2 text-sm leading-6 text-neutral-600">Call <%= business_setting.phone.presence || "our store phone" %> for same-day changes or urgent booking questions.</p>
    </div>
  </aside>
</section>
