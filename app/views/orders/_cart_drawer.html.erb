<div class="section-card p-4 md:p-5">
  <div class="mb-3 flex items-center justify-between">
    <div>
      <p class="eyebrow">Order Bag</p>
      <h2 class="text-3xl text-neutral-950">Your Cart</h2>
    </div>
    <% if cart.count.positive? %>
      <%= button_to "Clear", cart_clear_path, method: :delete, class: "text-xs font-semibold text-rose-600 hover:text-rose-700", form: { data: { turbo_confirm: "Clear cart?" } } %>
    <% end %>
  </div>

  <% if cart.empty? %>
    <p class="rounded-lg border border-[#e6d7bd] bg-[#fff8ec] p-4 text-sm text-neutral-600">No items yet. Add dumplings, wontons, or sides from the menu.</p>
  <% else %>
    <div class="space-y-3">
      <% cart.line_items.each do |line_item| %>
        <div class="rounded-lg border border-[#e6d7bd] bg-white p-3">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-semibold"><%= line_item.menu_item.name %></p>
              <p class="text-xs text-neutral-500"><%= money(line_item.menu_item.price_cents) %> each</p>
            </div>
            <p class="text-sm font-semibold"><%= money(line_item.total_cents) %></p>
          </div>
          <div class="mt-3 flex items-center justify-between gap-2">
            <div class="inline-flex items-center gap-2 rounded-full border border-[#e6d7bd] px-2 py-1">
              <%= button_to "-", cart_item_update_path(line_item.menu_item), method: :patch, params: { quantity: line_item.quantity - 1 }, class: "h-7 w-7 rounded-full bg-[#fff8ec] text-sm font-bold", form_class: "inline" %>
              <span class="min-w-6 text-center text-sm font-semibold"><%= line_item.quantity %></span>
              <%= button_to "+", cart_item_update_path(line_item.menu_item), method: :patch, params: { quantity: line_item.quantity + 1 }, class: "h-7 w-7 rounded-full bg-[#fff8ec] text-sm font-bold", form_class: "inline" %>
            </div>
            <%= button_to "Remove", cart_item_remove_path(line_item.menu_item), method: :delete, class: "text-xs font-semibold text-rose-600" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-4 flex items-center justify-between border-t border-neutral-200 pt-4">
      <p class="text-sm font-semibold text-neutral-600">Subtotal</p>
      <p class="text-lg font-bold"><%= money(cart.subtotal_cents) %></p>
    </div>
  <% end %>
</div>
