<section class="warm-band">
  <div class="container-shell py-12">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="eyebrow">Menu</p>
        <h1 class="mt-3 text-5xl leading-tight text-neutral-950 md:text-6xl">Dumplings, wonton bowls, crisp sides, and drinks.</h1>
        <p class="mt-4 text-base leading-8 text-neutral-700">Prices and dishes are seeded from the photographed in-store menu. Choose a basket, bowl, set meal, or something pan-fried and golden.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <%= link_to "Order Now", order_path, class: "btn-primary" %>
        <%= link_to "Book a Table", book_path, class: "btn-secondary" %>
      </div>
    </div>
  </div>
</section>

<section class="container-shell py-8">
  <div class="sticky top-[76px] z-20 -mx-4 border-y border-[#e6d7bd] bg-[#fff8ec]/95 px-4 py-3 backdrop-blur sm:mx-0 sm:rounded-full sm:border">
    <div class="flex gap-2 overflow-x-auto">
      <% @categories.each do |category| %>
        <% next if category.menu_items.select(&:active?).empty? %>
        <a href="#category-<%= category.id %>" class="chip whitespace-nowrap hover:border-[#c98b17] hover:text-neutral-950"><%= category.name %></a>
      <% end %>
    </div>
  </div>

  <div class="mt-10 space-y-14">
    <% @categories.each do |category| %>
      <% items = category.menu_items.select(&:active?) %>
      <% next if items.empty? %>

      <section id="category-<%= category.id %>" class="scroll-mt-32">
        <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="eyebrow"><%= items.count %> items</p>
            <h2 class="text-4xl text-neutral-950"><%= category.name %></h2>
            <% if menu_category_blurb(category.name).present? %>
              <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-600"><%= menu_category_blurb(category.name) %></p>
            <% end %>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          <% items.each do |item| %>
            <article class="menu-card">
              <%= menu_item_photo_tag(item, classes: "menu-image", alt: item.name) %>
              <div class="p-5">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="text-2xl leading-tight text-neutral-950"><%= item.name %></h3>
                  <span class="rounded-full bg-[#fff2d6] px-3 py-1 text-sm font-black text-[#b34834]"><%= money(item.price_cents) %></span>
                </div>
                <p class="mt-3 text-sm leading-6 text-neutral-600"><%= item.description %></p>
                <div class="mt-4 flex items-center justify-between gap-3">
                  <div class="flex flex-wrap gap-2">
                    <% item.dietary_tags.each do |tag| %>
                      <span class="chip"><%= tag %></span>
                    <% end %>
                  </div>
                  <%= link_to "Add to order", order_path(anchor: "item-#{item.id}"), class: "text-sm font-black text-[#c98b17] hover:text-neutral-950" %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</section>
