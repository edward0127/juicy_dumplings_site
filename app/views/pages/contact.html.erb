<section class="warm-band">
  <div class="container-shell py-12">
    <p class="eyebrow">Contact</p>
    <h1 class="mt-2 max-w-3xl text-5xl leading-tight text-neutral-950 md:text-6xl">Find us, call us, or send a message.</h1>
    <p class="mt-4 max-w-2xl text-base leading-8 text-neutral-700">For same-day order or booking changes, calling the shop is fastest. For general enquiries, send a message below.</p>
  </div>
</section>

<section class="container-shell grid gap-6 py-10 lg:grid-cols-[0.92fr_1.08fr]">
  <div class="space-y-6">
    <div class="section-card p-6 md:p-8">
      <h2 class="text-3xl text-neutral-950">Shop details</h2>
      <div class="mt-5 space-y-3 text-sm leading-6 text-neutral-700">
        <p><span class="font-black text-neutral-950">Address:</span> <%= full_business_address %></p>
        <p><span class="font-black text-neutral-950">Phone:</span> <%= business_setting.phone.presence || "Update in Admin" %></p>
        <p><span class="font-black text-neutral-950">Email:</span> <%= business_setting.email.presence || "Update in Admin" %></p>
      </div>
      <div class="mt-6 rounded-lg border border-[#e6d7bd] bg-[#fff8ec] p-4">
        <p class="text-xs font-black uppercase tracking-[0.14em] text-[#b34834]">Opening Hours</p>
        <div class="mt-2 space-y-1 text-sm text-neutral-700">
          <% opening_hours_lines.each do |line| %>
            <p><%= line %></p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="section-card p-6 md:p-8">
      <h2 class="text-3xl text-neutral-950">Send a message</h2>
      <%= form_with model: @contact_form, url: contact_path, class: "mt-5 space-y-4" do |f| %>
        <div>
          <%= f.label :name, "Name", class: "form-label" %>
          <%= f.text_field :name, class: "input-field", required: true %>
        </div>
        <div>
          <%= f.label :contact, "Email or Phone", class: "form-label" %>
          <%= f.text_field :contact, class: "input-field", required: true %>
        </div>
        <div>
          <%= f.label :message, "Message", class: "form-label" %>
          <%= f.text_area :message, rows: 4, class: "input-field", required: true %>
        </div>
        <div class="hidden">
          <%= f.label :website, "Leave this blank" %>
          <%= f.text_field :website, autocomplete: "off" %>
        </div>
        <%= f.submit "Send Message", class: "btn-primary w-full" %>
      <% end %>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg border border-[#e6d7bd] bg-white shadow-xl">
    <iframe
      title="Juicy Dumplings Map"
      class="h-full min-h-[720px] w-full border-0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      src="https://www.google.com/maps?q=<%= ERB::Util.url_encode(business_setting.address) %>&output=embed">
    </iframe>
  </div>
</section>
