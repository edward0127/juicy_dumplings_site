<section class="warm-band">
  <div class="container-shell grid min-h-[620px] items-center gap-10 py-12 lg:grid-cols-[1fr_0.92fr] lg:py-16">
    <div class="max-w-2xl">
      <p class="eyebrow"><%= business_setting.suburb %></p>
      <h1 class="mt-4 text-5xl leading-[0.95] text-neutral-950 md:text-7xl">Wuxi dumplings, warm soup, easy family meals.</h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-neutral-700">Juicy Dumplings is a friendly Doncaster East dumpling shop serving steamed baskets, comforting wonton bowls, crisp sides, and quick online pickup.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <%= link_to "Order Now", order_path, class: "btn-primary" %>
        <%= link_to "Book a Table", book_path, class: "btn-secondary" %>
        <%= link_to "View Menu", menu_path, class: "btn-gold" %>
      </div>
      <div class="mt-8 grid gap-3 text-sm font-semibold text-neutral-700 sm:grid-cols-3">
        <div class="rounded-lg border border-[#e6d7bd] bg-white/70 p-4">
          <p class="text-neutral-950">Handmade style</p>
          <p class="mt-1 text-xs text-neutral-600">Steamed, soup, and pan-fried choices.</p>
        </div>
        <div class="rounded-lg border border-[#e6d7bd] bg-white/70 p-4">
          <p class="text-neutral-950">Fast pickup</p>
          <p class="mt-1 text-xs text-neutral-600">Order ahead for lunch or dinner.</p>
        </div>
        <div class="rounded-lg border border-[#e6d7bd] bg-white/70 p-4">
          <p class="text-neutral-950">Local shop</p>
          <p class="mt-1 text-xs text-neutral-600"><%= full_business_address %></p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -left-4 top-8 hidden rounded-full bg-[#f4c84a] px-5 py-3 text-sm font-black text-neutral-950 shadow-lg lg:block">Signature Basket</div>
      <div class="overflow-hidden rounded-lg border-4 border-white bg-white shadow-2xl">
        <%= menu_item_photo_tag(@hero_item, classes: "h-[470px] w-full object-cover", alt: "#{@hero_item&.name || business_setting.business_name} signature dish") %>
      </div>
      <% if @hero_item %>
        <div class="mx-4 -mt-16 relative rounded-lg bg-[#24211f] p-5 text-white shadow-xl">
          <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#f4c84a]">Popular tonight</p>
          <div class="mt-2 flex items-start justify-between gap-4">
            <div>
              <h2 class="text-3xl"><%= @hero_item.name %></h2>
              <p class="mt-2 text-sm leading-6 text-[#e9dcc9]"><%= truncate(@hero_item.description, length: 110) %></p>
            </div>
            <p class="text-lg font-black text-[#f4c84a]"><%= money(@hero_item.price_cents) %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="container-shell py-14">
  <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
    <div>
      <p class="eyebrow">Signature Dishes</p>
      <h2 class="mt-2 text-4xl text-neutral-950">Start with the dumplings people come back for.</h2>
    </div>
    <%= link_to "See the full menu", menu_path, class: "btn-secondary self-start md:self-auto" %>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-3">
    <% @signature_items.each do |item| %>
      <article class="menu-card">
        <%= menu_item_photo_tag(item, classes: "menu-image", alt: item.name) %>
        <div class="p-5">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-2xl text-neutral-950"><%= item.name %></h3>
            <p class="font-black text-[#b34834]"><%= money(item.price_cents) %></p>
          </div>
          <p class="mt-3 text-sm leading-6 text-neutral-600"><%= truncate(item.description, length: 120) %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="bg-[#fffdf7] py-14">
  <div class="container-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="overflow-hidden rounded-lg border border-[#e6d7bd] bg-white shadow-xl">
      <%= image_tag "shop_front.jpg", alt: "#{business_setting.business_name} shop front", class: "h-[420px] w-full object-cover" %>
    </div>
    <div>
      <p class="eyebrow">Our Shop</p>
      <h2 class="mt-2 text-4xl leading-tight text-neutral-950">A bright little dumpling stop with a friendly sign out front.</h2>
      <p class="mt-4 text-base leading-8 text-neutral-700">The shop-front is simple and welcoming: cream signage, warm yellow accents, dark lettering, and a playful dumpling character. The website now follows that same tone: polished enough to trust, casual enough for a family dinner.</p>
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <div class="rounded-lg border border-[#e6d7bd] bg-white p-4">
          <p class="font-black text-neutral-950">Order pickup</p>
          <p class="mt-1 text-sm text-neutral-600">Choose dishes online and tell us when to prepare them.</p>
        </div>
        <div class="rounded-lg border border-[#e6d7bd] bg-white p-4">
          <p class="font-black text-neutral-950">Book dine-in</p>
          <p class="mt-1 text-sm text-neutral-600">Reserve a casual table for small groups and families.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container-shell py-14">
  <div class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end">
    <div>
      <p class="eyebrow">Best Sellers</p>
      <h2 class="mt-2 text-4xl text-neutral-950">Easy picks for first-time orders.</h2>
    </div>
    <div class="flex gap-3">
      <%= link_to "Order Online", order_path, class: "btn-primary" %>
      <%= link_to "Book", book_path, class: "btn-secondary" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% (@popular_items.presence || @signature_items).each do |item| %>
      <article class="menu-card">
        <%= menu_item_photo_tag(item, classes: "aspect-square w-full object-cover", alt: item.name) %>
        <div class="p-4">
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-xl leading-tight text-neutral-950"><%= item.name %></h3>
            <p class="font-black text-[#b34834]"><%= money(item.price_cents) %></p>
          </div>
          <p class="mt-2 text-sm leading-6 text-neutral-600"><%= truncate(item.description, length: 82) %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="warm-band py-14">
  <div class="container-shell grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
    <div>
      <p class="eyebrow">What Locals Notice</p>
      <h2 class="mt-2 text-4xl text-neutral-950">Comfort food, clear service, no fuss.</h2>
      <p class="mt-4 text-base leading-8 text-neutral-700">Everything important is easy to find: menu, order, booking, address, hours, and contact details. The food images now lead with real dumpling-shop dishes instead of generic placeholders.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <% @reviews.each do |review| %>
        <article class="rounded-lg border border-[#e6d7bd] bg-white p-5 shadow-sm">
          <p class="text-sm leading-6 text-neutral-700">"<%= review[:quote] %>"</p>
          <p class="mt-4 text-xs font-black uppercase tracking-[0.14em] text-[#b34834]"><%= review[:author] %></p>
          <p class="mt-1 text-xs font-semibold text-neutral-500"><%= rating_text(review[:rating]) %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section class="container-shell grid gap-6 py-14 lg:grid-cols-[0.95fr_1.05fr]">
  <div class="section-card p-6 md:p-8">
    <p class="eyebrow">Find Us</p>
    <h2 class="mt-2 text-4xl text-neutral-950">Visit Juicy Dumplings in Doncaster East.</h2>
    <div class="mt-5 space-y-3 text-sm leading-6 text-neutral-700">
      <p><span class="font-black text-neutral-950">Address:</span> <%= full_business_address %></p>
      <p><span class="font-black text-neutral-950">Phone:</span> <%= business_setting.phone.presence || "Update in Admin" %></p>
      <p><span class="font-black text-neutral-950">Email:</span> <%= business_setting.email.presence || "Update in Admin" %></p>
    </div>
    <div class="mt-6 rounded-lg border border-[#e6d7bd] bg-[#fff8ec] p-4">
      <p class="text-xs font-black uppercase tracking-[0.14em] text-[#b34834]">Opening Hours</p>
      <div class="mt-2 grid gap-1 text-sm text-neutral-700 sm:grid-cols-2">
        <% opening_hours_lines.each do |line| %>
          <p><%= line %></p>
        <% end %>
      </div>
    </div>
  </div>
  <div class="overflow-hidden rounded-lg border border-[#e6d7bd] bg-white shadow-xl">
    <iframe
      title="Juicy Dumplings Location"
      class="h-full min-h-[430px] w-full border-0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      src="https://www.google.com/maps?q=<%= ERB::Util.url_encode(business_setting.address) %>&output=embed">
    </iframe>
  </div>
</section>
