<h1>Thanks for your order, <%= @order.customer_name %>!</h1>
<p>Your order reference is <strong><%= @order.public_id %></strong>.</p>
<p>Total: <strong><%= number_to_currency(@order.total_cents / 100.0) %></strong></p>
<p>Pickup time: <%= @order.pickup_time&.strftime("%d %b %Y %I:%M %p") || "TBC" %></p>
