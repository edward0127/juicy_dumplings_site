<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Dining Room</p>
    <h1 class="text-4xl text-neutral-950">Bookings</h1>
    <p class="mt-2 text-sm text-neutral-600">Review guest details, party sizes, and reservation status.</p>
  </div>
  <%= link_to "Export CSV", export_admin_bookings_path(format: :csv), class: "btn-secondary self-start md:self-auto" %>
</div>

<div class="admin-mobile-list space-y-3 md:hidden">
  <% @bookings.each do |booking| %>
    <article class="admin-mobile-card">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="admin-mobile-label">Booking</p>
          <h2 class="mt-1 truncate text-lg font-black text-neutral-950"><%= booking.name %></h2>
          <p class="mt-1 text-xs font-bold text-neutral-500"><%= booking.booking_time.strftime("%d %b %I:%M %p") %></p>
        </div>
        <%= booking_status_badge(booking.status) %>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3">
        <div>
          <p class="admin-mobile-label">Guests</p>
          <p class="admin-mobile-value"><%= booking.party_size %></p>
        </div>
        <div>
          <p class="admin-mobile-label">Contact</p>
          <p class="admin-mobile-value break-words"><%= booking.phone.presence || booking.email.presence || "Not provided" %></p>
        </div>
      </div>

      <div class="admin-mobile-actions">
        <%= link_to "View booking", admin_booking_path(booking), class: "btn-secondary min-h-11 w-full justify-center px-4 py-2" %>
      </div>
    </article>
  <% end %>
</div>

<div class="admin-card hidden overflow-x-auto md:block">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Time</th>
        <th>Name</th>
        <th>Party</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @bookings.each do |booking| %>
        <tr>
          <td class="font-semibold"><%= booking.booking_time.strftime("%d %b %I:%M %p") %></td>
          <td class="font-black text-neutral-950"><%= booking.name %></td>
          <td><%= booking.party_size %> guests</td>
          <td><%= booking_status_badge(booking.status) %></td>
          <td class="text-right"><%= link_to "View", admin_booking_path(booking), class: "admin-action" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
