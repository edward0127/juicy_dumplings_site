<div class="mb-6">
  <p class="eyebrow">Trading Hours</p>
  <h1 class="text-4xl text-neutral-950"><%= @opening_hour.persisted? ? "Edit Opening Hour" : "New Opening Hour" %></h1>
  <p class="mt-2 text-sm text-neutral-600">Opening hours control customer pickup and booking slot availability.</p>
</div>

<div class="admin-card max-w-2xl p-6">
  <%= form_with model: [:admin, @opening_hour], class: "space-y-4" do |f| %>
    <% if @opening_hour.errors.any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">
        <ul class="list-disc pl-5">
          <% @opening_hour.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :day_of_week, "Day", class: "admin-label" %>
      <%= f.select :day_of_week, OpeningHour::DAYS.each_with_index.map { |name, idx| [name, idx] }, {}, class: "admin-input" %>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :opens_at, "Opens (24h HH:MM)", class: "admin-label" %>
        <%= f.text_field :opens_at, class: "admin-input", placeholder: "11:00" %>
      </div>
      <div>
        <%= f.label :closes_at, "Closes (24h HH:MM)", class: "admin-label" %>
        <%= f.text_field :closes_at, class: "admin-input", placeholder: "21:30" %>
      </div>
    </div>

    <label class="flex items-center gap-2 text-sm font-semibold">
      <%= f.check_box :closed %>
      Closed all day
    </label>

    <div class="flex flex-col gap-3 sm:flex-row">
      <%= f.submit class: "btn-primary justify-center" %>
      <%= link_to "Cancel", admin_opening_hours_path, class: "btn-secondary justify-center" %>
    </div>
  <% end %>
</div>
