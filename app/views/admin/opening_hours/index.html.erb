<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Trading Hours</p>
    <h1 class="text-4xl text-neutral-950">Opening Hours</h1>
    <p class="mt-2 text-sm text-neutral-600">These hours drive booking slots, pickup times, and public information.</p>
  </div>
  <%= link_to "Add Day", new_admin_opening_hour_path, class: "btn-primary self-start md:self-auto" %>
</div>

<div class="admin-mobile-list space-y-3 md:hidden">
  <% @opening_hours.each do |hour| %>
    <article class="admin-mobile-card">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="admin-mobile-label">Day</p>
          <h2 class="mt-1 text-lg font-black text-neutral-950"><%= hour.day_name %></h2>
        </div>
        <% if hour.closed? %>
          <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Closed</span>
        <% else %>
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Open</span>
        <% end %>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3">
        <div>
          <p class="admin-mobile-label">Open</p>
          <p class="admin-mobile-value"><%= hour.closed? ? "Closed" : hour.opens_at %></p>
        </div>
        <div>
          <p class="admin-mobile-label">Close</p>
          <p class="admin-mobile-value"><%= hour.closed? ? "Closed" : hour.closes_at %></p>
        </div>
      </div>

      <div class="admin-mobile-actions">
        <%= link_to "Edit hours", edit_admin_opening_hour_path(hour), class: "btn-secondary min-h-11 flex-1 justify-center px-4 py-2" %>
        <%= button_to "Delete", admin_opening_hour_path(hour), method: :delete, class: "min-h-11 rounded-full px-4 py-2 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete this day?" }, class: "flex-1 text-center" } %>
      </div>
    </article>
  <% end %>
</div>

<div class="admin-card hidden overflow-x-auto md:block">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Day</th>
        <th>Open</th>
        <th>Close</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @opening_hours.each do |hour| %>
        <tr>
          <td class="font-black text-neutral-950"><%= hour.day_name %></td>
          <td><%= hour.opens_at %></td>
          <td><%= hour.closes_at %></td>
          <td>
            <% if hour.closed? %>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Closed</span>
            <% else %>
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Open</span>
            <% end %>
          </td>
          <td class="text-right">
            <%= link_to "Edit", edit_admin_opening_hour_path(hour), class: "admin-action" %>
            <%= button_to "Delete", admin_opening_hour_path(hour), method: :delete, class: "ml-3 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete this day?" }, class: "inline" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
