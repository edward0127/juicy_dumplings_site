<!DOCTYPE html>
<html>
  <head>
    <title>Admin Sign In | <%= business_setting.business_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="admin-shell min-h-screen text-neutral-900">
    <main class="container-shell flex min-h-screen items-center justify-center py-10">
      <section class="admin-card w-full max-w-md p-6 sm:p-8">
        <div class="flex items-center gap-3">
          <span class="brand-mark">JD</span>
          <div>
            <p class="text-lg font-black text-neutral-950">Restaurant Admin</p>
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#c98b17]"><%= business_setting.business_name %></p>
          </div>
        </div>

        <div class="mt-8">
          <p class="eyebrow">Staff Access</p>
          <h1 class="mt-2 text-3xl font-black text-neutral-950">Sign in to manage the restaurant</h1>
          <p class="mt-3 text-sm leading-6 text-neutral-600">Use the admin username and password to manage orders, bookings, menu items, hours, and shop details.</p>
        </div>

        <% flash.each do |key, value| %>
          <% tone = key.to_s == "alert" ? "border-rose-200 bg-rose-50 text-rose-700" : "border-emerald-200 bg-emerald-50 text-emerald-700" %>
          <div class="mt-5 rounded-lg border px-4 py-3 text-sm font-semibold <%= tone %>"><%= value %></div>
        <% end %>

        <%= form_with url: admin_login_path, method: :post, class: "mt-6 space-y-4" do %>
          <div>
            <%= label_tag :username, "Username", class: "admin-label" %>
            <%= text_field_tag :username, params[:username].to_s, class: "admin-input", autocomplete: "username", required: true, autofocus: true %>
          </div>

          <div>
            <%= label_tag :password, "Password", class: "admin-label" %>
            <%= password_field_tag :password, nil, class: "admin-input", autocomplete: "current-password", required: true %>
          </div>

          <%= submit_tag "Sign in", class: "btn-primary w-full cursor-pointer justify-center" %>
        <% end %>

        <div class="mt-6 border-t border-[#e6ded0] pt-5">
          <%= link_to "Back to public site", root_path, class: "admin-action" %>
        </div>
      </section>
    </main>
  </body>
</html>
