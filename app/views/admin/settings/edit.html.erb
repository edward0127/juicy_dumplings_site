<div class="mb-6">
  <p class="eyebrow">Restaurant Settings</p>
  <h1 class="text-4xl text-neutral-950">Business Settings</h1>
  <p class="mt-2 text-sm text-neutral-600">These details power the public site, order flow, booking capacity, and staff notifications.</p>
</div>

<div class="admin-card max-w-5xl p-6">
  <%= form_with model: @setting, url: admin_settings_path, class: "space-y-6" do |f| %>
    <% if @setting.errors.any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">
        <ul class="list-disc pl-5">
          <% @setting.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <section>
      <p class="admin-label">Public Shop Details</p>
      <div class="mt-3 grid gap-4 md:grid-cols-2">
        <div>
          <%= f.label :business_name, class: "admin-label" %>
          <%= f.text_field :business_name, class: "admin-input" %>
        </div>
        <div>
          <%= f.label :suburb, class: "admin-label" %>
          <%= f.text_field :suburb, class: "admin-input" %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :address, class: "admin-label" %>
          <%= f.text_field :address, class: "admin-input" %>
        </div>
        <div>
          <%= f.label :phone, class: "admin-label" %>
          <%= f.text_field :phone, class: "admin-input" %>
        </div>
        <div>
          <%= f.label :email, class: "admin-label" %>
          <%= f.email_field :email, class: "admin-input" %>
        </div>
      </div>
    </section>

    <section class="rounded-lg border border-[#e6ded0] bg-[#fbf7ef] p-4">
      <p class="admin-label">Operations</p>
      <div class="mt-3 grid gap-4 md:grid-cols-2">
        <div>
          <%= f.label :owner_email, class: "admin-label" %>
          <%= f.email_field :owner_email, class: "admin-input" %>
        </div>
        <div>
          <%= f.label :price_range, class: "admin-label" %>
          <%= f.text_field :price_range, class: "admin-input" %>
        </div>
        <div>
          <%= f.label :slot_interval_minutes, class: "admin-label" %>
          <%= f.select :slot_interval_minutes, BusinessSetting::SLOT_INTERVAL_OPTIONS, {}, class: "admin-input" %>
        </div>
        <div>
          <%= f.label :max_bookings_per_slot, class: "admin-label" %>
          <%= f.number_field :max_bookings_per_slot, class: "admin-input" %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :hours_note, class: "admin-label" %>
          <%= f.text_area :hours_note, rows: 3, class: "admin-input" %>
        </div>
      </div>
    </section>

    <section>
      <p class="admin-label">Customer Flows</p>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <label class="rounded-lg border border-[#e6ded0] bg-white p-4 text-sm font-semibold"><%= f.check_box :ordering_enabled, class: "mr-2" %> Ordering enabled</label>
        <label class="rounded-lg border border-[#e6ded0] bg-white p-4 text-sm font-semibold"><%= f.check_box :pay_at_pickup_enabled, class: "mr-2" %> Pay at pickup enabled</label>
      </div>
    </section>

    <div class="flex flex-col gap-3 sm:flex-row">
      <%= f.submit "Save Settings", class: "btn-primary justify-center" %>
      <%= link_to "Back to Dashboard", admin_root_path, class: "btn-secondary justify-center" %>
    </div>
  <% end %>
</div>
