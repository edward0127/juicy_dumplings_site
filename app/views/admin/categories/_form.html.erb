<div class="mb-6">
  <p class="eyebrow">Menu Structure</p>
  <h1 class="text-4xl text-neutral-950"><%= @category.persisted? ? "Edit Category" : "New Category" %></h1>
  <p class="mt-2 text-sm text-neutral-600">Categories shape the public menu and order page navigation.</p>
</div>

<div class="admin-card max-w-2xl p-6">
  <%= form_with model: [:admin, @category], class: "space-y-4" do |f| %>
    <% if @category.errors.any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">
        <ul class="list-disc pl-5">
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Category Name", class: "admin-label" %>
      <%= f.text_field :name, class: "admin-input" %>
    </div>

    <div>
      <%= f.label :position, "Display Order", class: "admin-label" %>
      <%= f.number_field :position, class: "admin-input" %>
    </div>

    <label class="flex items-center gap-2 text-sm font-semibold">
      <%= f.check_box :active %>
      Active on public menu
    </label>

    <div class="flex flex-col gap-3 sm:flex-row">
      <%= f.submit class: "btn-primary justify-center" %>
      <%= link_to "Cancel", admin_categories_path, class: "btn-secondary justify-center" %>
    </div>
  <% end %>
</div>
