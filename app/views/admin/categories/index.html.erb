<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Menu Structure</p>
    <h1 class="text-4xl text-neutral-950">Categories</h1>
    <p class="mt-2 text-sm text-neutral-600">Control how the public menu is grouped and ordered.</p>
  </div>
  <%= link_to "New Category", new_admin_category_path, class: "btn-primary self-start md:self-auto" %>
</div>

<div class="admin-mobile-list space-y-3 md:hidden">
  <% @categories.each do |category| %>
    <article class="admin-mobile-card">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="admin-mobile-label">Category</p>
          <h2 class="mt-1 truncate text-lg font-black text-neutral-950"><%= category.name %></h2>
        </div>
        <% if category.active? %>
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Active</span>
        <% else %>
          <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Hidden</span>
        <% end %>
      </div>

      <div class="mt-4">
        <p class="admin-mobile-label">Position</p>
        <p class="admin-mobile-value"><%= category.position %></p>
      </div>

      <div class="admin-mobile-actions">
        <%= link_to "Edit category", edit_admin_category_path(category), class: "btn-secondary min-h-11 flex-1 justify-center px-4 py-2" %>
        <%= button_to "Delete", admin_category_path(category), method: :delete, class: "min-h-11 rounded-full px-4 py-2 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete category?" }, class: "flex-1 text-center" } %>
      </div>
    </article>
  <% end %>
</div>

<div class="admin-card hidden overflow-x-auto md:block">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Position</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td class="font-black text-neutral-950"><%= category.name %></td>
          <td><%= category.position %></td>
          <td>
            <% if category.active? %>
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Active</span>
            <% else %>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Hidden</span>
            <% end %>
          </td>
          <td class="text-right">
            <%= link_to "Edit", edit_admin_category_path(category), class: "admin-action" %>
            <%= button_to "Delete", admin_category_path(category), method: :delete, class: "ml-3 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete category?" }, class: "inline" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
