<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Menu Structure</p>
    <h1 class="text-4xl text-neutral-950">Categories</h1>
    <p class="mt-2 text-sm text-neutral-600">Control how the public menu is grouped and ordered.</p>
  </div>
  <%= link_to "New Category", new_admin_category_path, class: "btn-primary self-start md:self-auto" %>
</div>

<div class="admin-card overflow-x-auto">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Position</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td class="font-black text-neutral-950"><%= category.name %></td>
          <td><%= category.position %></td>
          <td>
            <% if category.active? %>
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Active</span>
            <% else %>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Hidden</span>
            <% end %>
          </td>
          <td class="text-right">
            <%= link_to "Edit", edit_admin_category_path(category), class: "admin-action" %>
            <%= button_to "Delete", admin_category_path(category), method: :delete, class: "ml-3 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete category?" }, class: "inline" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
