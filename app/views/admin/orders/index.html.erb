<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Kitchen Flow</p>
    <h1 class="text-4xl text-neutral-950">Orders</h1>
    <p class="mt-2 text-sm text-neutral-600">Review customer details, pickup times, payment, and kitchen status.</p>
  </div>
  <%= link_to "Export CSV", export_admin_orders_path(format: :csv), class: "btn-secondary self-start md:self-auto" %>
</div>

<div class="admin-card overflow-x-auto">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Ref</th>
        <th>Customer</th>
        <th>Type</th>
        <th>Total</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td class="font-black text-neutral-950"><%= order.public_id %></td>
          <td>
            <p class="font-semibold"><%= order.customer_name %></p>
            <p class="mt-1 text-xs text-neutral-500"><%= order.created_at.strftime("%d %b %I:%M %p") %></p>
          </td>
          <td><%= order.order_type.humanize %></td>
          <td class="font-black text-[#b34834]"><%= money(order.total_cents) %></td>
          <td><%= order_status_badge(order.status) %></td>
          <td class="text-right"><%= link_to "View", admin_order_path(order), class: "admin-action" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
