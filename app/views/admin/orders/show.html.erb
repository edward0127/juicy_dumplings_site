<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Order Detail</p>
    <h1 class="text-4xl text-neutral-950">Order <%= @order.public_id %></h1>
    <p class="mt-2 text-sm text-neutral-600">Placed <%= @order.created_at.strftime("%d %b %Y %I:%M %p") %></p>
  </div>
  <%= link_to "Back to Orders", admin_orders_path, class: "btn-secondary self-start md:self-auto" %>
</div>

<div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
  <div class="admin-card p-6">
    <div class="grid gap-4 text-sm sm:grid-cols-2">
      <div class="admin-muted-panel"><span class="font-black text-neutral-950">Customer:</span> <%= @order.customer_name %></div>
      <div class="admin-muted-panel"><span class="font-black text-neutral-950">Type:</span> <%= @order.order_type.humanize %></div>
      <div class="admin-muted-panel"><span class="font-black text-neutral-950">Phone:</span> <%= @order.customer_phone.presence || "Not provided" %></div>
      <div class="admin-muted-panel"><span class="font-black text-neutral-950">Email:</span> <%= @order.customer_email.presence || "Not provided" %></div>
      <div class="admin-muted-panel"><span class="font-black text-neutral-950">Pickup:</span> <%= @order.pickup_time&.strftime("%d %b %I:%M %p") || "Not selected" %></div>
      <div class="admin-muted-panel"><span class="font-black text-neutral-950">Paid:</span> <%= @order.paid? ? "Yes" : "No" %></div>
    </div>

    <% if @order.delivery_address.present? || @order.notes.present? %>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        <% if @order.delivery_address.present? %>
          <div class="admin-muted-panel">
            <p class="admin-label">Delivery Address</p>
            <p><%= @order.delivery_address %></p>
          </div>
        <% end %>
        <% if @order.notes.present? %>
          <div class="admin-muted-panel">
            <p class="admin-label">Order Notes</p>
            <div><%= simple_format(@order.notes) %></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="mt-5 rounded-lg border border-[#e6ded0] p-4">
      <p class="admin-label">Items</p>
      <ul class="mt-3 space-y-3 text-sm">
        <% @order.order_items.each do |item| %>
          <li class="flex items-center justify-between gap-3 border-b border-[#eee5d8] pb-3 last:border-0 last:pb-0">
            <span><span class="font-black"><%= item.quantity %> x</span> <%= item.menu_item.name %></span>
            <span class="font-black text-[#b34834]"><%= money(item.total_cents) %></span>
          </li>
        <% end %>
      </ul>
      <p class="mt-4 border-t border-[#eee5d8] pt-4 text-right text-lg font-black">Total: <%= money(@order.total_cents) %></p>
    </div>
  </div>

  <div class="admin-card p-6">
    <p class="admin-label">Service Status</p>
    <div class="mt-2"><%= order_status_badge(@order.status) %></div>

    <%= form_with model: [:admin, @order], class: "mt-5 space-y-4" do |f| %>
      <div>
        <%= f.label :status, class: "admin-label" %>
        <%= f.select :status, Order.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "admin-input" %>
      </div>

      <label class="flex items-center gap-2 text-sm font-semibold">
        <%= f.check_box :paid %>
        Mark as paid
      </label>

      <%= f.submit "Save Order", class: "btn-primary w-full justify-center" %>
    <% end %>
  </div>
</div>
