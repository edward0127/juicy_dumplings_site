<div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
  <div>
    <p class="eyebrow">Menu Management</p>
    <h1 class="text-4xl text-neutral-950">Menu Items</h1>
    <p class="mt-2 text-sm text-neutral-600">Manage dish names, pricing, categories, photos, and ordering visibility.</p>
  </div>
  <%= link_to "New Item", new_admin_menu_item_path, class: "btn-primary self-start md:self-auto" %>
</div>

<div class="admin-mobile-list space-y-3 md:hidden">
  <% @menu_items.each do |item| %>
    <article class="admin-mobile-card">
      <div class="flex gap-3">
        <%= menu_item_photo_tag(item, classes: "h-20 w-20 flex-none rounded-lg object-cover", alt: item.name) %>
        <div class="min-w-0 flex-1">
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p class="truncate text-base font-black text-neutral-950"><%= item.name %></p>
              <p class="mt-1 text-xs font-bold text-neutral-500"><%= item.category.name %></p>
            </div>
            <p class="flex-none text-base font-black text-[#b34834]"><%= money(item.price_cents) %></p>
          </div>

          <% if item.active? %>
            <span class="mt-2 inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Active</span>
          <% else %>
            <span class="mt-2 inline-flex rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Hidden</span>
          <% end %>
        </div>
      </div>

      <% if item.description.present? %>
        <p class="mt-3 text-sm leading-6 text-neutral-600"><%= truncate(item.description, length: 120) %></p>
      <% end %>

      <div class="mt-3 flex flex-wrap gap-2">
        <% if item.dietary_tags.any? %>
          <% item.dietary_tags.each do |tag| %>
            <span class="chip"><%= tag %></span>
          <% end %>
        <% else %>
          <span class="chip">No tags</span>
        <% end %>
      </div>

      <div class="admin-mobile-actions">
        <%= link_to "Edit item", edit_admin_menu_item_path(item), class: "btn-secondary min-h-11 flex-1 justify-center px-4 py-2" %>
        <%= button_to "Delete", admin_menu_item_path(item), method: :delete, class: "min-h-11 rounded-full px-4 py-2 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete menu item?" }, class: "flex-1 text-center" } %>
      </div>
    </article>
  <% end %>
</div>

<div class="admin-card hidden overflow-x-auto md:block">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Category</th>
        <th>Price</th>
        <th>Tags</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @menu_items.each do |item| %>
        <tr>
          <td>
            <div class="flex min-w-[260px] items-center gap-3">
              <%= menu_item_photo_tag(item, classes: "h-16 w-16 flex-none rounded-lg object-cover", alt: item.name) %>
              <div>
                <p class="font-black text-neutral-950"><%= item.name %></p>
                <p class="mt-1 text-xs leading-5 text-neutral-500"><%= truncate(item.description, length: 76) %></p>
              </div>
            </div>
          </td>
          <td class="text-neutral-700"><%= item.category.name %></td>
          <td class="font-black text-[#b34834]"><%= money(item.price_cents) %></td>
          <td class="text-xs text-neutral-600"><%= item.dietary_tags.presence&.join(", ") || "None" %></td>
          <td>
            <% if item.active? %>
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">Active</span>
            <% else %>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-black text-neutral-600">Hidden</span>
            <% end %>
          </td>
          <td class="text-right">
            <%= link_to "Edit", edit_admin_menu_item_path(item), class: "admin-action" %>
            <%= button_to "Delete", admin_menu_item_path(item), method: :delete, class: "ml-3 text-sm font-black text-rose-600", form: { data: { turbo_confirm: "Delete menu item?" }, class: "inline" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
