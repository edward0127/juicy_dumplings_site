<div class="mb-6">
  <p class="eyebrow">Menu Management</p>
  <h1 class="text-4xl text-neutral-950"><%= @menu_item.persisted? ? "Edit Menu Item" : "New Menu Item" %></h1>
  <p class="mt-2 text-sm text-neutral-600">Keep dish details clear for customers and staff. Uploaded photos are preferred over fallback URLs.</p>
</div>

<%= form_with model: [:admin, @menu_item], class: "grid gap-6 lg:grid-cols-[1fr_360px]" do |f| %>
  <div class="admin-card p-6">
    <% if @menu_item.errors.any? %>
      <div class="mb-5 rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700">
        <ul class="list-disc pl-5">
          <% @menu_item.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :category_id, "Menu Category", class: "admin-label" %>
        <%= f.collection_select :category_id, @categories, :id, :name, {}, class: "admin-input" %>
      </div>
      <div>
        <%= f.label :position, "Display Order", class: "admin-label" %>
        <%= f.number_field :position, class: "admin-input" %>
      </div>
    </div>

    <div class="mt-4">
      <%= f.label :name, "Dish Name", class: "admin-label" %>
      <%= f.text_field :name, class: "admin-input" %>
    </div>

    <div class="mt-4">
      <%= f.label :description, class: "admin-label" %>
      <%= f.text_area :description, rows: 4, class: "admin-input" %>
    </div>

    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :price_cents, "Price in cents", class: "admin-label" %>
        <%= f.number_field :price_cents, class: "admin-input" %>
        <p class="mt-1 text-xs text-neutral-500">Example: enter 680 for $6.80.</p>
      </div>
      <div>
        <%= f.label :image_url, "Fallback image URL", class: "admin-label" %>
        <%= f.text_field :image_url, class: "admin-input" %>
        <p class="mt-1 text-xs text-neutral-500">Used only when no uploaded photo is attached.</p>
      </div>
    </div>

    <div class="mt-5 rounded-lg border border-[#e6ded0] bg-[#fbf7ef] p-4">
      <p class="admin-label">Menu Flags</p>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="flex items-center gap-2 text-sm font-semibold"><%= f.check_box :active %> Active on public menu</label>
        <label class="flex items-center gap-2 text-sm font-semibold"><%= f.check_box :spicy %> Spicy</label>
        <label class="flex items-center gap-2 text-sm font-semibold"><%= f.check_box :vegetarian %> Vegetarian</label>
        <label class="flex items-center gap-2 text-sm font-semibold"><%= f.check_box :gluten_free %> Gluten Free</label>
      </div>
    </div>
  </div>

  <aside class="space-y-4">
    <div class="admin-card p-5">
      <p class="admin-label">Dish Photo</p>
      <% if @menu_item.photo.attached? || @menu_item.image_url.present? %>
        <%= menu_item_photo_tag(@menu_item, classes: "mt-2 aspect-[4/3] w-full rounded-lg object-cover", alt: @menu_item.name.presence || "Menu item preview") %>
        <% if @menu_item.photo.attached? %>
          <label class="mt-3 flex items-center gap-2 text-sm text-neutral-700">
            <%= f.check_box :remove_photo %>
            <span>Remove uploaded photo</span>
          </label>
        <% end %>
      <% else %>
        <div class="mt-2 flex aspect-[4/3] w-full items-center justify-center rounded-lg border border-dashed border-[#d8cdbb] bg-[#fbf7ef] text-sm font-semibold text-neutral-500">No photo yet</div>
      <% end %>
      <div class="mt-4">
        <%= f.file_field :photo, accept: "image/*", class: "admin-input" %>
        <p class="mt-2 text-xs leading-5 text-neutral-500">Upload a real dish photo where possible. Maximum size is 5 MB.</p>
      </div>
    </div>

    <div class="admin-card p-5">
      <p class="admin-label">Actions</p>
      <div class="mt-3 flex flex-col gap-3">
        <%= f.submit class: "btn-primary w-full justify-center" %>
        <%= link_to "Cancel", admin_menu_items_path, class: "btn-secondary w-full justify-center" %>
      </div>
    </div>
  </aside>
<% end %>
