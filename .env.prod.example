RAILS_ENV=production
HOST=juicydumplings.tudouke.com
APP_PORT_BIND=3013
SQLITE_DATABASE=/data/production.sqlite3
MAIL_FROM=no-reply@juicydumplings.tudouke.com

RAILS_MASTER_KEY=<set-on-server-only>
SECRET_KEY_BASE=<set-on-server-only>
ADMIN_USER=<set-on-server-only>
ADMIN_PASS=<set-on-server-only>

# Optional business notifications
OWNER_EMAIL=<set-on-server-only>

# Active Storage uses local disk first; switch to amazon only after S3 is configured.
ACTIVE_STORAGE_SERVICE=local

# Optional later S3 + CloudFront setup:
# ACTIVE_STORAGE_SERVICE=amazon
# AWS_ACCESS_KEY_ID=<set-on-server-only>
# AWS_SECRET_ACCESS_KEY=<set-on-server-only>
# AWS_REGION=ap-southeast-2
# AWS_S3_BUCKET=juicy-dumplings-site-production
# PUBLIC_UPLOAD_ASSET_HOST=https://<cloudfront-distribution-domain>

# Optional Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Optional SMTP
SMTP_ADDRESS=
SMTP_PORT=587
# Preferred names:
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=plain
SMTP_STARTTLS=true
SMTP_DOMAIN=
# Supported aliases, useful when a provider/platform already uses these names:
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS=true

# Optional SMS webhook
SMS_WEBHOOK_URL=
