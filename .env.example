# App
HOST=localhost
APP_PORT=3000

# SQLite
SQLITE_DATABASE=storage/development.sqlite3
SQLITE_TEST_DATABASE=storage/test.sqlite3

# Admin Basic Auth
ADMIN_USER=admin
ADMIN_PASS=change-me

# Business notifications
OWNER_EMAIL=owner@example.com
MAIL_FROM=no-reply@example.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Optional SMTP
SMTP_ADDRESS=
SMTP_PORT=587
# Preferred names:
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=plain
SMTP_STARTTLS=true
SMTP_DOMAIN=
# Supported aliases, useful when a provider/platform already uses these names:
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS=true

# Optional SMS webhook
SMS_WEBHOOK_URL=
